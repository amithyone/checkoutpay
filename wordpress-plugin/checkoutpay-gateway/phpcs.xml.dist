<?xml version="1.0"?>
<ruleset name="CheckoutPay Gateway">
	<description>PHPCS rules for the CheckoutPay WooCommerce gateway plugin (directory slug: checkoutpay-gateway).</description>

	<file>.</file>

	<exclude-pattern>/vendor/*</exclude-pattern>

	<rule ref="WordPress">
		<properties>
			<property name="text_domain" type="array">
				<element value="checkoutpay-gateway"/>
			</property>
		</properties>
	</rule>
</ruleset>
