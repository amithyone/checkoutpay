APP_NAME="Email Payment Gateway"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

# NigTax admin SPA (used in messages and redirects for tax-role admins)
TAX_ADMIN_URL=https://nigtax.com/admin

# NigTax certified PDF payments — REQUIRED for paid certified reports on nigtax.com
# Integer primary key from the `businesses` table (same merchant account that should receive VA payments).
# That business must have at least one row in business_websites (approved website) for webhooks.
# Find ids: SELECT id, name FROM businesses;  or use Checkout admin → Businesses.
# After changing: php artisan config:clear
NIGTAX_PAYMENT_BUSINESS_ID=
# Optional: override payment.approved webhook base URL; if empty, the business website URL is used
NIGTAX_PAYMENT_WEBHOOK_URL=

# NigTax PRO (Taxcalculate): monthly membership slug and auto-seeded product (migration 2026_04_04_120001).
# After setting NIGTAX_PAYMENT_BUSINESS_ID, run: php artisan migrate
NIGTAX_PRO_MEMBERSHIP_SLUG=nigtax-pro
# After NigTax PRO password reset, users are redirected here (e.g. https://nigtax.com). Optional; defaults to APP_URL.
NIGTAX_CALCULATOR_URL=

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database Configuration (MySQL)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=checkout
DB_USERNAME=checkoutpay_user
DB_PASSWORD=checkoutpay_pass_2024
# Security hardening for SQL injection / destructive SQL
SQL_INJECTION_GUARD_ENABLED=true
DB_QUERY_FIREWALL_ENABLED=true
# Keep false so migrations/CLI maintenance are not blocked
DB_QUERY_FIREWALL_BLOCK_IN_CONSOLE=false
# Daily backup retention (used by scripts/mysql-backup.sh)
MYSQL_BACKUP_KEEP=5
MYSQL_BACKUP_COMPRESS=true
# Secure receiver API for live -> checkout data sync
LIVE_SYNC_ENABLED=false
LIVE_SYNC_KEY_ID=live-site-1
LIVE_SYNC_SECRET=
LIVE_SYNC_MAX_DRIFT_SECONDS=300
LIVE_SYNC_NONCE_TTL_SECONDS=600
# Optional source IP allowlist (comma-separated), e.g. 1.2.3.4,5.6.7.8
LIVE_SYNC_ALLOWED_IPS=

# Alternative: PostgreSQL
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=payment_gateway
# DB_USERNAME=postgres
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Email Configuration (for receiving bank notifications)
# Gmail Setup: https://myaccount.google.com/apppasswords
EMAIL_HOST=imap.gmail.com
EMAIL_PORT=993
EMAIL_ENCRYPTION=ssl
EMAIL_VALIDATE_CERT=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-16-character-app-password

# Payment Configuration
PAYMENT_AMOUNT_TOLERANCE=0.01
PAYMENT_EXPIRATION_HOURS=24

# Global match: newest N unmatched emails per run (cron + admin); default 200
GLOBAL_MATCH_MAX_EMAILS=200

# Webhook Configuration
WEBHOOK_TIMEOUT=30
WEBHOOK_RETRY_ATTEMPTS=3

# VTU.ng (airtime/data/electricity). Required for consumer app Pay Bills (airtime/data) and WhatsApp wallet VTU.
# Set VTU_NG_ENABLED=true plus USERNAME and PASSWORD (JWT is obtained automatically from VTU_NG_API_BASE).
VTU_NG_ENABLED=false
VTU_NG_API_BASE=https://vtu.ng/wp-json/api/v2
VTU_NG_USERNAME=
VTU_NG_PASSWORD=
VTU_NG_PIN=
VTU_NG_TIMEOUT=60
# Refund/reversal webhook protection
VTU_NG_WEBHOOK_SECRET=
VTU_NG_WEBHOOK_ALLOWED_IPS=
VTU_NG_REFUND_STATUSES=refund,refunded,reversed,reversal,failed

# Match attempt logs: delete records older than this many days (daily cleanup at 02:00)
MATCH_ATTEMPTS_RETENTION_DAYS=30

# Google reCAPTCHA v3 (registration / rental checkout spam protection)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
RECAPTCHA_ENABLED=true
RECAPTCHA_VERSION=v3
RECAPTCHA_SCORE_THRESHOLD=0.5

# Transaction Transfer Feature (Super Admin Only)
# Set to true to enable, false to disable transaction transfer feature
TRANSACTION_TRANSFER_ENABLED=true

# NUBAN (account number validation – https://nuban.com.ng)
NUBAN_API_KEY=
NUBAN_BASE_URL=https://app.nuban.com.ng/api
NUBAN_POSSIBLE_BANKS_URL=https://app.nuban.com.ng/possible-banks
NUBAN_TIMEOUT_SECONDS=10

# MavonPay (instant withdrawals)
MEVONPAY_BASE_URL=
MEVONPAY_SECRET_KEY=
MEVONPAY_DEBIT_ACCOUNT_NAME=
MEVONPAY_DEBIT_ACCOUNT_NUMBER=
MEVONPAY_CURRENT_PASSWORD=
MEVONPAY_TIMEOUT_SECONDS=20

# Firebase Cloud Messaging (mobile push — optional; unrelated to NigTax / memberships)
FCM_PROJECT_ID=
# IMPORTANT: Never paste multi-line JSON here. Dotenv parses the whole file as one line per variable;
# a multi-line value breaks .env and then ALL Artisan commands fail (migrate, queue, etc.).
# Use ONE of:
#   - Absolute path: FCM_SERVICE_ACCOUNT_JSON=/var/www/checkout/storage/app/fcm-service-account.json
#   - Path from project root (single line): FCM_SERVICE_ACCOUNT_JSON=storage/app/fcm-service-account.json
#   - Single-line minified JSON only if you know what you are doing (easy to break quoting).
FCM_SERVICE_ACCOUNT_JSON=

# WhatsApp (Evolution API) — inbound webhook + OTP email to link renter accounts
# Webhook URL: {WHATSAPP_APP_URL or APP_URL}/api/v1/whatsapp/webhook
# Live checklist: (1) Set WHATSAPP_APP_URL to public HTTPS Checkout (e.g. https://check-outpay.com).
# (2) WHATSAPP_EVOLUTION_* = base URL, api key, default instance; WHATSAPP_EVOLUTION_INSTANCE_RENTALS = rentals-only line (must match Evolution instance name on webhooks).
# (3) WHATSAPP_WEBHOOK_SECRET = optional; if set, Evolution webhook must use ?secret=... or header X-Checkout-WhatsApp-Secret.
# (4) On the live server: php artisan config:clear && php artisan whatsapp:configure-webhook --url='https://YOUR-DOMAIN/api/v1/whatsapp/webhook?secret=YOUR_SECRET'
#    (or save the same values in Admin → WhatsApp wallet — they override .env when filled.)
# Public Checkout base URL for WhatsApp (magic links, php artisan whatsapp:configure-webhook). Use HTTPS in production.
WHATSAPP_APP_URL=

# Customer-facing portals (WhatsApp copy / links). Defaults: business check-outnow.com, rentals abjrentals.ng, tax nigtax.com
PORTAL_URL_BUSINESS=https://check-outnow.com
PORTAL_URL_RENTALS=https://abjrentals.ng
PORTAL_URL_TAX=https://nigtax.com

# WhatsApp Wallet: web URL for signup, KYC, and full transaction history (falls back to WHATSAPP_APP_URL)
WHATSAPP_WALLET_APP_URL=
# Tier 1 caps (WhatsApp-only wallet before Rubies VA)
WHATSAPP_WALLET_TIER1_MAX_BALANCE=50000
WHATSAPP_WALLET_TIER1_DAILY_TRANSFER=50000
# Tier 1 pay-in: MevonPay createtempva (new account each time user taps WALLET → 1). Requires MEVONPAY_TEMP_VA_REGISTRATION_NUMBER.
WHATSAPP_WALLET_TIER1_TEMP_VA_FNAME=WhatsApp
WHATSAPP_WALLET_TIER1_TEMP_VA_LNAME=User
WHATSAPP_WALLET_TIER1_TEMP_VA_TTL_HOURS=48

WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_EVOLUTION_BASE_URL=https://wa-api.example.com
WHATSAPP_EVOLUTION_API_KEY=
WHATSAPP_EVOLUTION_INSTANCE=
# Evolution instance name for the rentals-only WhatsApp line (inbound routing). Must match Evolution; case-insensitive. Admin Setting whatsapp_evolution_instance_rentals overrides when set.
WHATSAPP_EVOLUTION_INSTANCE_RENTALS=
# Optional: wallet outbound instance (defaults to WHATSAPP_EVOLUTION_INSTANCE). Admin whatsapp_evolution_instance_wallet overrides when set.
# WHATSAPP_EVOLUTION_INSTANCE_WALLET=
# Optional: extra Evolution instance names per region (must match Evolution API). See config/whatsapp_wallet_regions.php
# WHATSAPP_EVOLUTION_INSTANCE_NAMIBIA=Namibia
# WHATSAPP_EVOLUTION_INSTANCE_ZAMBIA=Zambia
# WHATSAPP_EVOLUTION_INSTANCE_ZIMBABWE=Zimbabwe
# WHATSAPP_EVOLUTION_INSTANCE_BOTSWANA=Botswana
# WHATSAPP_EVOLUTION_INSTANCE_SOUTHAFRICA=South Africa
# WHATSAPP_EVOLUTION_INSTANCE_BENIN=Benin
# WHATSAPP_EVOLUTION_INSTANCE_TANZANIA=Tanzania
WHATSAPP_OTP_TTL_MINUTES=10
WHATSAPP_OTP_MAX_ATTEMPTS=5

# Tagine restaurant app — optional LEGACY bridge (Tagine → POST /api/tagine/* with X-Tagine-Otp-Secret).
# If Tagine uses CHECKOUT_API_KEY instead, it calls POST /api/v1/whatsapp-wallet/send-message + /ensure — leave this empty.
# When set: Checkout does NOT generate OTP; Tagine stores the code; Checkout only sends WhatsApp via Evolution.
# Must match CHECKOUT_TAGINE_OTP_SECRET on Tagine when using the bridge.
TAGINE_OTP_SECRET=
# Optional: Checkout `renters.id` for Tagine merchant (wallet pay-ins / settlement wiring later).
TAGINE_WALLET_RENTER_ID=

# Merchant API: POST /api/v1/whatsapp-wallet/* with X-API-Key. Admin must enable whatsapp_wallet_api_enabled on the business.
# Pay flow: POST /api/v1/whatsapp-wallet/pay/start → WhatsApp + secure PIN link → credits business + payment.approved webhook (no PIN-less debit API).
# TTL (minutes) for the secure pay link / intent.
WHATSAPP_WALLET_PARTNER_PAY_INTENT_TTL_MINUTES=30

# CheckoutNow in-app support chat (POST /api/v1/internal/consumer-chat/reply). Generate a long random secret; omit to disable server replies.
# CONSUMER_CHAT_INTERNAL_REPLY_KEY=
# CONSUMER_CHAT_MAX_BODY=4000

# Beta Badge Display
# Set to true to show floating "BETA" badge on all pages, false to hide
# If not set, defaults to database setting (can be toggled in Admin Settings)
# SHOW_BETA_BADGE=true
LIVE_SYNC_RECEIVER_URL=https://your-receiver-domain.com/api/v1/sync/live
LIVE_SYNC_KEY_ID=live-site-1
LIVE_SYNC_SECRET=the-same-secret-as-receiver

# Developer Program: thank-you page links after application (optional)
# DEVELOPER_PROGRAM_SLACK_URL=https://join.slack.com/t/...
# DEVELOPER_PROGRAM_WHATSAPP_URL=https://chat.whatsapp.com/...